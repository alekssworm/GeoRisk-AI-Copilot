GEORISK_API_URL=http://localhost:8000
GEORISK_MODEL_PATH=models/georisk_model.joblib
GEORISK_RAG_INDEX_PATH=storage/rag_index.joblib
GEORISK_UPLOAD_DIR=storage/uploads
GEORISK_MAX_UPLOAD_MB=25
GEORISK_PDF_PROCESSING_TIMEOUT_SECONDS=30
GEORISK_RAG_CHUNK_SIZE=1200
GEORISK_RAG_CHUNK_OVERLAP=180
GEORISK_LLM_MAX_PROMPT_CHARS=16000
GEORISK_CORS_ALLOW_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
GEORISK_CORS_ALLOW_CREDENTIALS=false
GEORISK_API_KEY=
GEORISK_ALLOW_UNAUTHENTICATED=false
GEORISK_RATE_LIMIT_WINDOW_SECONDS=60
GEORISK_RATE_LIMIT_REQUESTS=120
GEORISK_TRAIN_RATE_LIMIT_REQUESTS=5
GEORISK_UPLOAD_RATE_LIMIT_REQUESTS=20
GEORISK_RAG_RATE_LIMIT_REQUESTS=60

# Optional. When unset, the RAG assistant uses a local grounded fallback.
OPENAI_API_KEY=
GEORISK_LLM_MODEL=gpt-4o-mini
